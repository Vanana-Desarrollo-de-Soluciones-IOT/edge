EDGE_DATABASE_PATH=clair_edge.db

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Docs (optional)
EDGE_PUBLIC_BASE_URL=http://127.0.0.1:5000

# CORS (use comma-separated origins in production, e.g. https://admin.example.com)
EDGE_CORS_ALLOWED_ORIGINS=*
EDGE_CORS_ALLOWED_HEADERS=Content-Type,X-Hardware-Id,X-API-Key
