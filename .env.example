EDGE_DATABASE_PATH=clair_edge.db
EDGE_SYNC_DEVICES_ON_STARTUP=true

# clair-core integration
CLAIR_CORE_BASE_URL=http://localhost:8080

# Shared secret (MUST MATCH clair-core EDGE_TO_CORE_TOKEN)
EDGE_TO_CORE_TOKEN=change-me-long-random-secret

# Docs (optional)
EDGE_PUBLIC_BASE_URL=http://127.0.0.1:5000

# CORS (use comma-separated origins in production, e.g. https://admin.example.com)
EDGE_CORS_ALLOWED_ORIGINS=*
EDGE_CORS_ALLOWED_HEADERS=Content-Type,X-Hardware-Id,X-Device-Secret,X-Edge-Token
